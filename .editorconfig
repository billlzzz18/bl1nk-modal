root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.rs]
indent_size = 4
max_line_length = 100

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.sh]
indent_size = 4

[*.ps1]
indent_size = 4

[Makefile]
indent_style = tab
