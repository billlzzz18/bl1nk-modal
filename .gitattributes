# Normalize everything to LF in the repo; let Git handle checkout conversion.
* text=auto eol=lf

*.py text eol=lf
*.rs text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Lockfiles are machine-generated — exclude from diffs/linguist stats.
uv.lock linguist-generated=true -diff
Cargo.lock linguist-generated=true -diff

# Binary assets — never text-normalize these.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
