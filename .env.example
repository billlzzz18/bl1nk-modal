# Repo-wide setup. Copy to .env and fill in — .env is gitignored.
#
# Load these for a command with uv, no code changes needed:
#   uv run --env-file .env <command>

# --- Modal auth (alternative to interactive `modal setup`) ---
# `modal setup` opens a browser for OAuth, which doesn't work well on
# headless machines or Termux. Create a token instead:
#   https://modal.com/settings -> API Tokens -> New Token
# or generate one for CI: https://modal.com/docs/guide/service-users
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
