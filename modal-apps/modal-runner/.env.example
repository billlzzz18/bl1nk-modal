# Copy to .env and fill in for local dev/testing — .env is gitignored.
# In production these are set as Modal secrets (see README.md), not env vars;
# this file is only for running main.py / pytest locally.
#
#   uv run --env-file .env pytest
#   uv run --env-file .env modal serve main.py

# --- cratedb-secret: CrateDB connection (task storage) ---
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# --- line-notify-secret: LINE Notify ---
LINE_TOKEN=

# --- webhook-secrets: verify incoming webhook signatures ---
GITHUB_SECRET=
GITLAB_SECRET=
AZURE_DEVOPS_USERNAME=
AZURE_DEVOPS_PASSWORD=
