# Copy to .env and fill in for local dev/testing of opencode.py (the
# "sovereign-gateway" GitHub App webhook) — .env is gitignored.
#
#   uv run --env-file .env modal serve opencode.py

# GitHub App backing the sovereign-gateway label automation.
# Create at: https://github.com/settings/apps -> New GitHub App
GITHUB_APP_ID=
# Private key (PEM), with literal newlines escaped as \n on one line.
GITHUB_PRIVATE_KEY=
# Webhook secret configured on the same GitHub App.
GITHUB_WEBHOOK_SECRET=
