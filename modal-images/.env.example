# Copy to .env and fill in for local dev/testing — .env is gitignored.
# In production this is set as the Modal secret `bl1nk-search-auth` (see
# .claude/skills/modal-image-builds/references/ai-agent-search-runtime.md),
# not an env var; this file is only for running search_service.py / pytest
# locally.
#
#   uv run --env-file .env pytest

# --- bl1nk-search-auth: bearer token auth for the search API ---
# Leave both blank to disable auth entirely (assert_token() no-ops when
# BL1NK_API_TOKEN is empty) — useful for local testing.
BL1NK_API_TOKEN=
BL1NK_TOKEN_ID=default-token
